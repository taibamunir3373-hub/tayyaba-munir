<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold"><i class="bi bi-people-fill me-2"></i>Patients</h3>
  <a href="/patients/add" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Add Patient</a>
</div>

<div class="card p-4 mb-4">
  <form method="GET" action="/patients" class="d-flex gap-2">
    <input type="text" name="search" value="<%= search %>" class="form-control" placeholder="Search patients by name...">
    <button class="btn btn-outline-primary">Search</button>
    <a href="/patients" class="btn btn-outline-secondary">Clear</a>
  </form>
</div>

<div class="card">
  <div class="table-responsive">
    <table class="table table-hover mb-0">
      <thead class="table-primary">
        <tr>
          <th>#</th><th>Name</th><th>Phone</th><th>Age</th><th>Gender</th><th>Blood Group</th><th>Allergies</th><th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (patients.length === 0) { %>
          <tr><td colspan="8" class="text-center text-muted py-4">No patients found</td></tr>
        <% } %>
        <% patients.forEach((p, i) => { %>
          <tr>
            <td><%= i+1 %></td>
            <td><strong><%= p.name %></strong></td>
            <td><%= p.phone %></td>
            <td><%= p.age || '-' %></td>
            <td><span class="badge bg-info text-dark"><%= p.gender || '-' %></span></td>
            <td>
              <% if(p.bloodGroup) { %>
                <span class="badge bg-danger"><%= p.bloodGroup %></span>
              <% } else { %>
                <span class="text-muted">-</span>
              <% } %>
            </td>
            <td><small class="text-muted"><%= p.allergies || 'None' %></small></td>
            <td>
              <a href="/patients/edit/<%= p._id %>" class="btn btn-sm btn-warning me-1"><i class="bi bi-pencil"></i></a>
              <form action="/patients/delete/<%= p._id %>" method="POST" style="display:inline" onsubmit="return confirm('Delete this patient?')">
                <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('../partials/footer') %>