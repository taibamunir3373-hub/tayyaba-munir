</div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
  // Dark mode toggle — localStorage se yaad rakhta hai
  function toggleDark() {
    document.body.classList.toggle('dark-mode');
    const isDark = document.body.classList.contains('dark-mode');
    localStorage.setItem('darkMode', isDark);
    document.getElementById('darkBtn').innerHTML = isDark ? '☀️ Light Mode' : '🌙 Dark Mode';
  }

  // Page load pe dark mode apply karo agar pehle set tha
  window.addEventListener('DOMContentLoaded', () => {
    if (localStorage.getItem('darkMode') === 'true') {
      document.body.classList.add('dark-mode');
      const btn = document.getElementById('darkBtn');
      if (btn) btn.innerHTML = '☀️ Light Mode';
    }
  });
</script>
</body>
</html>