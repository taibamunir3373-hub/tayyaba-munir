<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold"><%= doctor ? 'Edit Doctor' : 'Add Doctor' %></h3>
  <a href="/doctors" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

<div class="card p-4" style="max-width:600px">
  <form action="/doctors/<%= doctor ? 'edit/' + doctor._id : 'add' %>" method="POST">
    <div class="mb-3">
      <label class="form-label fw-semibold">Full Name</label>
      <input type="text" name="name" class="form-control" value="<%= doctor ? doctor.name : '' %>" required>
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Specialization</label>
      <input type="text" name="specialization" class="form-control" value="<%= doctor ? doctor.specialization : '' %>" required placeholder="e.g. Cardiology, Neurology">
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Email</label>
      <input type="email" name="email" class="form-control" value="<%= doctor ? doctor.email : '' %>" required>
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Phone</label>
      <input type="text" name="phone" class="form-control" value="<%= doctor ? doctor.phone : '' %>">
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Consultation Fee (Rs.)</label>
      <input type="number" name="fee" class="form-control" value="<%= doctor ? doctor.fee : '' %>">
    </div>
    <div class="mb-4">
      <label class="form-label fw-semibold">Available Days</label>
      <div class="d-flex flex-wrap gap-2">
        <% ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'].forEach(day => { %>
          <div class="form-check">
            <input class="form-check-input" type="checkbox" name="availableDays" value="<%= day %>"
              <%= doctor && doctor.availableDays && doctor.availableDays.includes(day) ? 'checked' : '' %>>
            <label class="form-check-label"><%= day %></label>
          </div>
        <% }) %>
      </div>
    </div>
    <button type="submit" class="btn btn-success px-4"><%= doctor ? 'Update Doctor' : 'Add Doctor' %></button>
  </form>
</div>

<%- include('../partials/footer') %>