<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold"><i class="bi bi-person-circle me-2"></i>My Profile</h3>
  <a href="/" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

<div class="row g-4">
  <div class="col-md-4">
    <div class="card p-4 text-center">
      <div style="width:100px;height:100px;background:linear-gradient(135deg,#0d6efd,#0dcaf0);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 20px;font-size:2.5rem;color:white;font-weight:bold;">
        <%= user.name.charAt(0).toUpperCase() %>
      </div>
      <h4 class="fw-bold"><%= user.name %></h4>
      <p class="text-muted"><%= user.email %></p>
      <span class="badge bg-primary px-3 py-2"><%= user.role %></span>
      <hr>
      <div class="text-start">
        <div class="d-flex justify-content-between mb-2">
          <span class="text-muted">Member Since</span>
          <span class="fw-semibold"><%= new Date(user.createdAt).toDateString() %></span>
        </div>
        <div class="d-flex justify-content-between">
          <span class="text-muted">Status</span>
          <span class="badge bg-success">Active</span>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-8">
    <div class="card p-4">
      <h5 class="fw-bold mb-4"><i class="bi bi-pencil-square me-2"></i>Edit Profile</h5>
      <form action="/profile" method="POST">
        <div class="mb-3">
          <label class="form-label fw-semibold">Full Name</label>
          <input type="text" name="name" class="form-control form-control-lg" value="<%= user.name %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label fw-semibold">Email</label>
          <input type="email" class="form-control form-control-lg" value="<%= user.email %>" disabled>
          <small class="text-muted">Email cannot be changed</small>
        </div>
        <div class="mb-4">
          <label class="form-label fw-semibold">Role</label>
          <input type="text" class="form-control form-control-lg" value="<%= user.role %>" disabled>
        </div>
        <button type="submit" class="btn btn-primary px-4">
          <i class="bi bi-check-circle me-1"></i> Update Profile
        </button>
      </form>
    </div>

    <div class="card p-4 mt-4">
      <h5 class="fw-bold mb-3"><i class="bi bi-shield-lock me-2"></i>Account Info</h5>
      <div class="row g-3">
        <div class="col-md-4">
          <div class="p-3 rounded text-center" style="background:#e3f2fd">
            <i class="bi bi-calendar-check fs-2 text-primary"></i>
            <div class="fw-bold mt-2">Account Active</div>
            <small class="text-muted">All features enabled</small>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 rounded text-center" style="background:#e8f5e9">
            <i class="bi bi-shield-check fs-2 text-success"></i>
            <div class="fw-bold mt-2">Secure Login</div>
            <small class="text-muted">Password encrypted</small>
          </div>
        </div>
        <div class="col-md-4">
          <div class="p-3 rounded text-center" style="background:#fff3e0">
            <i class="bi bi-person-badge fs-2 text-warning"></i>
            <div class="fw-bold mt-2"><%= user.role %></div>
            <small class="text-muted">Access level</small>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>