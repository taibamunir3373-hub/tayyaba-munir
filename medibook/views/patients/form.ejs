<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold"><%= patient ? 'Edit Patient' : 'Add Patient' %></h3>
  <a href="/patients" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back</a>
</div>

<div class="card p-4" style="max-width:700px">
  <form action="/patients/<%= patient ? 'edit/' + patient._id : 'add' %>" method="POST">
    
    <h6 class="fw-bold text-primary mb-3"><i class="bi bi-person-fill me-2"></i>Personal Information</h6>
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Full Name</label>
        <input type="text" name="name" class="form-control" value="<%= patient ? patient.name : '' %>" required>
      </div>
      <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Email</label>
        <input type="email" name="email" class="form-control" value="<%= patient ? patient.email : '' %>" required>
      </div>
    </div>
    <div class="row">
      <div class="col-md-6 mb-3">
        <label class="form-label fw-semibold">Phone</label>
        <input type="text" name="phone" class="form-control" value="<%= patient ? patient.phone : '' %>" required>
      </div>
      <div class="col-md-3 mb-3">
        <label class="form-label fw-semibold">Age</label>
        <input type="number" name="age" class="form-control" value="<%= patient ? patient.age : '' %>">
      </div>
      <div class="col-md-3 mb-3">
        <label class="form-label fw-semibold">Gender</label>
        <select name="gender" class="form-select">
          <option value="">Select</option>
          <option <%= patient && patient.gender==='Male' ? 'selected':'' %>>Male</option>
          <option <%= patient && patient.gender==='Female' ? 'selected':'' %>>Female</option>
          <option <%= patient && patient.gender==='Other' ? 'selected':'' %>>Other</option>
        </select>
      </div>
    </div>
    <div class="mb-3">
      <label class="form-label fw-semibold">Address</label>
      <input type="text" name="address" class="form-control" value="<%= patient ? patient.address : '' %>">
    </div>

    <hr>
    <h6 class="fw-bold text-danger mb-3"><i class="bi bi-heart-pulse-fill me-2"></i>Medical Information</h6>
    <div class="row">
      <div class="col-md-4 mb-3">
        <label class="form-label fw-semibold">Blood Group</label>
        <select name="bloodGroup" class="form-select">
          <option value="">Select</option>
          <% ['A+','A-','B+','B-','AB+','AB-','O+','O-'].forEach(bg => { %>
            <option <%= patient && patient.bloodGroup===bg ? 'selected':'' %>><%= bg %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-8 mb-3">
        <label class="form-label fw-semibold">Allergies</label>
        <input type="text" name="allergies" class="form-control" placeholder="e.g. Penicillin, Dust, Pollen" value="<%= patient ? patient.allergies : '' %>">
      </div>
    </div>
    <div class="mb-4">
      <label class="form-label fw-semibold">Medical History / Notes</label>
      <textarea name="medHistory" class="form-control" rows="3" placeholder="Previous conditions, surgeries, medications..."><%= patient ? patient.medHistory : '' %></textarea>
    </div>

    <button type="submit" class="btn btn-primary px-4">
      <i class="bi bi-check-circle me-1"></i><%= patient ? 'Update Patient' : 'Add Patient' %>
    </button>
  </form>
</div>

<%- include('../partials/footer') %>