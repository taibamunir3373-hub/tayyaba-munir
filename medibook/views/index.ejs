<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h3 class="fw-bold"><i class="bi bi-speedometer2 me-2"></i>Dashboard</h3>
  <span class="text-muted">Welcome, <%= user.name %>! 👋</span>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card p-4 text-white" style="background:#0d6efd">
      <div class="d-flex justify-content-between align-items-center">
        <div><div class="fs-2 fw-bold"><%= patientCount %></div><div>Total Patients</div></div>
        <i class="bi bi-people-fill fs-1 opacity-50"></i>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card p-4 text-white" style="background:#198754">
      <div class="d-flex justify-content-between align-items-center">
        <div><div class="fs-2 fw-bold"><%= doctorCount %></div><div>Total Doctors</div></div>
        <i class="bi bi-person-badge-fill fs-1 opacity-50"></i>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card p-4 text-white" style="background:#fd7e14">
      <div class="d-flex justify-content-between align-items-center">
        <div><div class="fs-2 fw-bold"><%= appointmentCount %></div><div>Total Appointments</div></div>
        <i class="bi bi-calendar-check-fill fs-1 opacity-50"></i>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card p-4 text-white" style="background:#6f42c1">
      <div class="d-flex justify-content-between align-items-center">
        <div><div class="fs-2 fw-bold"><%= pendingCount %></div><div>Pending</div></div>
        <i class="bi bi-clock-fill fs-1 opacity-50"></i>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-6">
    <div class="card p-4">
      <h5 class="fw-bold mb-3">Appointment Status</h5>
      <canvas id="statusChart" height="200"></canvas>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card p-4">
      <h5 class="fw-bold mb-3">Recent Appointments</h5>
      <table class="table table-sm">
        <thead class="table-light">
          <tr><th>Patient</th><th>Doctor</th><th>Status</th></tr>
        </thead>
        <tbody>
          <% recentAppointments.forEach(a => { %>
          <tr>
            <td><%= a.patient ? a.patient.name : '-' %></td>
            <td><%= a.doctor ? a.doctor.name : '-' %></td>
            <td>
              <% if(a.status === 'confirmed') { %>
                <span class="badge bg-success">Confirmed</span>
              <% } else if(a.status === 'cancelled') { %>
                <span class="badge bg-danger">Cancelled</span>
              <% } else { %>
                <span class="badge bg-warning text-dark">Pending</span>
              <% } %>
            </td>
          </tr>
          <% }) %>
          <% if(recentAppointments.length === 0) { %>
            <tr><td colspan="3" class="text-center text-muted">No appointments yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<div class="card p-4">
  <h5 class="fw-bold mb-3">Quick Actions</h5>
  <div class="d-flex gap-3">
    <a href="/patients/add" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i> Add Patient</a>
    <a href="/doctors/add" class="btn btn-success"><i class="bi bi-plus-circle me-1"></i> Add Doctor</a>
    <a href="/appointments/add" class="btn btn-warning text-white"><i class="bi bi-plus-circle me-1"></i> Book Appointment</a>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
  const ctx = document.getElementById('statusChart').getContext('2d');
  new Chart(ctx, {
    type: 'doughnut',
    data: {
      labels: ['Pending', 'Confirmed', 'Cancelled'],
      datasets: [{
        data: [<%= pendingCount %>, <%= confirmedCount %>, <%= cancelledCount %>],
        backgroundColor: ['#ffc107', '#198754', '#dc3545'],
        borderWidth: 0
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { position: 'bottom' }
      }
    }
  });
</script>

<%- include('partials/footer') %>