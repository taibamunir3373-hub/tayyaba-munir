<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - BlogApp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background-color: #f4f7f6; height: 100vh; display: flex; align-items: center; justify-content: center; }
        .auth-card { width: 100%; max-width: 400px; padding: 30px; border: none; border-radius: 12px; box-shadow: 0 8px 24px rgba(0,0,0,0.1); background: #fff; }
        .btn-custom { background-color: #198754; color: white; border-radius: 8px; padding: 10px; }
        .btn-custom:hover { background-color: #146c43; color: white; }
    </style>
</head>
<body>

<div class="auth-card">
    <h2 class="text-center fw-bold mb-4">Login</h2>
    <form action="/login" method="POST">
        <div class="mb-3">
            <label class="form-label">Email Address</label>
            <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Password</label>
            <input type="password" name="password" class="form-control" placeholder="Enter password" required>
        </div>
        <div class="d-grid mt-4">
            <button type="submit" class="btn btn-custom">Login</button>
        </div>
    </form>
    <p class="text-center mt-4 mb-0">Don't have an account? <a href="/register" class="text-success text-decoration-none fw-semibold">Create Account</a></p>
</div>

</body>
</html>