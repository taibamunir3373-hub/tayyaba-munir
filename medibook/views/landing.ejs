<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MediBook - Doctor Appointment System</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Segoe UI', sans-serif; }
    .hero { background: linear-gradient(135deg, #1a237e 0%, #0d6efd 50%, #0dcaf0 100%); min-height: 100vh; display: flex; align-items: center; color: white; }
    .hero h1 { font-size: 3.5rem; font-weight: 700; line-height: 1.2; }
    .hero p { font-size: 1.2rem; opacity: 0.9; }
    .brand-logo { font-size: 2rem; font-weight: 700; margin-bottom: 40px; }
    .feature-card { background: white; border-radius: 16px; padding: 30px; text-align: center; box-shadow: 0 4px 20px rgba(0,0,0,0.08); transition: transform 0.3s; height: 100%; }
    .feature-card:hover { transform: translateY(-5px); }
    .feature-icon { width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1.8rem; margin: 0 auto 20px; }
    .stats-section { background: #f8f9fa; padding: 80px 0; }
    .stat-box { text-align: center; padding: 30px; }
    .stat-number { font-size: 3rem; font-weight: 700; color: #0d6efd; }
    .navbar-landing { position: absolute; top: 0; left: 0; right: 0; padding: 20px 40px; display: flex; justify-content: space-between; align-items: center; }
    .btn-hero { padding: 14px 36px; border-radius: 50px; font-size: 1.1rem; font-weight: 600; }
    .floating-card { background: white; border-radius: 16px; padding: 20px; box-shadow: 0 8px 32px rgba(0,0,0,0.15); color: #333; max-width: 280px; }
    .footer-dark { background: #1a237e; color: white; padding: 40px 0; }
  </style>
</head>
<body>

<!-- Navbar -->
<div class="navbar-landing">
  <div style="color:white; font-size:1.4rem; font-weight:700;">
    <i class="bi bi-heart-pulse-fill me-2"></i>MediBook
  </div>
  <div class="d-flex gap-3">
    <a href="/auth/login" class="btn btn-outline-light btn-hero" style="padding:10px 28px">Login</a>
    <a href="/auth/signup" class="btn btn-light btn-hero" style="padding:10px 28px; color:#0d6efd">Sign Up</a>
  </div>
</div>

<!-- Hero Section -->
<section class="hero">
  <div class="container">
    <div class="row align-items-center">
      <div class="col-lg-6">
        <div class="brand-logo">
          <i class="bi bi-heart-pulse-fill me-2"></i>MediBook
        </div>
        <h1 class="mb-4">Smart Doctor Appointment System</h1>
        <p class="mb-5">Manage patients, doctors, and appointments efficiently. Built for modern healthcare management.</p>
        <div class="d-flex gap-3 flex-wrap">
          <a href="/auth/signup" class="btn btn-light btn-hero" style="color:#0d6efd">
            <i class="bi bi-rocket-takeoff me-2"></i>Get Started
          </a>
          <a href="/auth/login" class="btn btn-outline-light btn-hero">
            <i class="bi bi-box-arrow-in-right me-2"></i>Login
          </a>
        </div>
      </div>
      <div class="col-lg-6 d-none d-lg-block text-end">
        <div class="floating-card ms-auto">
          <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width:45px;height:45px;background:#e3f2fd;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#0d6efd;font-size:1.2rem">
              <i class="bi bi-calendar-check"></i>
            </div>
            <div>
              <div style="font-weight:600;font-size:14px">Appointment Booked!</div>
              <div style="color:#666;font-size:12px">Dr. Sarah — 10:00 AM</div>
            </div>
          </div>
          <hr>
          <div class="d-flex justify-content-between">
            <div class="text-center">
              <div style="font-size:1.4rem;font-weight:700;color:#0d6efd">24</div>
              <div style="font-size:11px;color:#666">Patients</div>
            </div>
            <div class="text-center">
              <div style="font-size:1.4rem;font-weight:700;color:#198754">8</div>
              <div style="font-size:11px;color:#666">Doctors</div>
            </div>
            <div class="text-center">
              <div style="font-size:1.4rem;font-weight:700;color:#fd7e14">12</div>
              <div style="font-size:11px;color:#666">Today</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Features Section -->
<section style="padding: 80px 0; background: white;">
  <div class="container">
    <div class="text-center mb-5">
      <h2 style="font-size:2.2rem;font-weight:700;color:#1a237e">Everything You Need</h2>
      <p class="text-muted">Complete hospital management in one place</p>
    </div>
    <div class="row g-4">
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon" style="background:#e3f2fd;">
            <i class="bi bi-people-fill" style="color:#0d6efd"></i>
          </div>
          <h5 class="fw-bold mb-2">Patient Management</h5>
          <p class="text-muted">Add, edit, search patients with complete medical history and records.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon" style="background:#e8f5e9;">
            <i class="bi bi-person-badge-fill" style="color:#198754"></i>
          </div>
          <h5 class="fw-bold mb-2">Doctor Profiles</h5>
          <p class="text-muted">Manage doctors with specializations, schedules, and consultation fees.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon" style="background:#fff3e0;">
            <i class="bi bi-calendar-check-fill" style="color:#fd7e14"></i>
          </div>
          <h5 class="fw-bold mb-2">Appointments</h5>
          <p class="text-muted">Book, confirm, and track appointments with printable slips.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon" style="background:#f3e5f5;">
            <i class="bi bi-graph-up" style="color:#6f42c1"></i>
          </div>
          <h5 class="fw-bold mb-2">Analytics Dashboard</h5>
          <p class="text-muted">Visual charts and statistics for better decision making.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon" style="background:#e8f5e9;">
            <i class="bi bi-shield-check" style="color:#198754"></i>
          </div>
          <h5 class="fw-bold mb-2">Secure Login</h5>
          <p class="text-muted">Role-based authentication to keep your data safe and secure.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="feature-card">
          <div class="feature-icon" style="background:#e3f2fd;">
            <i class="bi bi-printer-fill" style="color:#0d6efd"></i>
          </div>
          <h5 class="fw-bold mb-2">Print Slips</h5>
          <p class="text-muted">Generate and print professional appointment slips instantly.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats Section -->
<section class="stats-section">
  <div class="container">
    <div class="row">
      <div class="col-md-3">
        <div class="stat-box">
          <div class="stat-number">500+</div>
          <div class="text-muted">Patients Managed</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-box">
          <div class="stat-number">50+</div>
          <div class="text-muted">Doctors Registered</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-box">
          <div class="stat-number">1000+</div>
          <div class="text-muted">Appointments Booked</div>
        </div>
      </div>
      <div class="col-md-3">
        <div class="stat-box">
          <div class="stat-number">99%</div>
          <div class="text-muted">Satisfaction Rate</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="footer-dark">
  <div class="container text-center">
    <div style="font-size:1.5rem;font-weight:700;margin-bottom:10px">
      <i class="bi bi-heart-pulse-fill me-2"></i>MediBook
    </div>
    <p style="opacity:0.7">Doctor Appointment System — CSC337 Advanced Web Technologies</p>
    <p style="opacity:0.5;font-size:13px;margin-top:10px">COMSATS University Islamabad, Vehari Campus</p>
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>